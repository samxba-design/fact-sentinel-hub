# SentiWatch Environment Variables
# Copy this file to .env and fill in your values
# These are configured as Supabase Edge Function secrets (not in a local .env for production)

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI Keys ──────────────────────────────────────────────────────────────────
# Google AI (Gemini) — Powers AI analysis, YouTube understanding, Topic Watch
# Get a free API key at: https://aistudio.google.com/app/apikey
# This is the PREFERRED AI key — set this first
GOOGLE_API_KEY=

# Lovable AI Gateway — Alternative AI provider (fallback if no GOOGLE_API_KEY)
# Required if GOOGLE_API_KEY is not set
LOVABLE_API_KEY=

# ─── Data Sources ─────────────────────────────────────────────────────────────
# Brave Search API — for Topic Watch research
BRAVE_SEARCH_API_KEY=

# Firecrawl — for content scraping and link analysis
FIRECRAWL_API_KEY=

# YouTube Data API v3 (free, 10k units/day)
# Get at: https://console.cloud.google.com → Enable YouTube Data API v3
YOUTUBE_API_KEY=

# X (Twitter) Bearer Token (requires Basic plan, $100/mo paid to X)
TWITTER_BEARER_TOKEN=

# Reddit API credentials (free)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ─── Notifications ────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Payments ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
